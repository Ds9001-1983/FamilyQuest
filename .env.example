# PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@host:5432/levelmission

# Long random secret used to sign session cookies.
# Generate: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
# Required in production; ephemeral dev fallback is used when unset in development.
SESSION_SECRET=

# Optional: HTTP listen address (defaults: host 0.0.0.0, port 5000)
PORT=5000
HOST=0.0.0.0

# Optional: set to "production" to enable secure cookies + trust proxy + strict checks.
NODE_ENV=development

# JWT signing secret used for mobile/native clients (min. 32 chars).
# Generate: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=

# Comma-separated list of allowed CORS origins in production (e.g. https://app.example.com).
# Requests without an Origin header (native Expo apps) are always accepted.
CORS_ORIGINS=
