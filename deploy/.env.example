# =============================================================================
# LevelMission - Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#   nano .env
# =============================================================================

# -----------------------------------------------------------------------------
# ERFORDERLICH: Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# ERFORDERLICH: Datenbank-Verbindung
# -----------------------------------------------------------------------------
# Lokale PostgreSQL:
DATABASE_URL=postgresql://familyquest:DEIN_PASSWORT@localhost:5432/familyquest

# Oder Neon Cloud (serverless):
# DATABASE_URL=postgresql://user:password@ep-xyz.eu-central-1.aws.neon.tech/familyquest?sslmode=require

# -----------------------------------------------------------------------------
# ERFORDERLICH: Session Secret
# -----------------------------------------------------------------------------
# Mindestens 32 Zeichen! Generiere mit:
#   openssl rand -base64 32
SESSION_SECRET=hier_mindestens_32_zeichen_zufallsstring_einfuegen

# -----------------------------------------------------------------------------
# OPTIONAL: Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL: Domain für CORS (falls benötigt)
# -----------------------------------------------------------------------------
# DOMAIN=https://deine-domain.de
